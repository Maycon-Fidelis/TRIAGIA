# ── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://radia:radia123@localhost:5432/radia

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Armazenamento ────────────────────────────────────────────────────────────
STORAGE_PATH=/app/storage

# ── Supabase (opcional — deixe vazio para usar armazenamento local) ───────────
SUPABASE_URL=
SUPABASE_KEY=

# ── IA ───────────────────────────────────────────────────────────────────────
# "demo" → heurística rápida sem GPU  |  "ml" → DenseNet121 (requer PyTorch)
AI_MODE=demo

# ── Aplicação ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=troque-esta-chave-em-producao-use-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
